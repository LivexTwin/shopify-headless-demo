---
import DefaultLayout from "../../layouts/DefaultLayout.astro";
import SeoHead from "@components/SeoHead.astro";

const product = {
  title: "INTENT",
  price: "55",
  images: [
    "/placeholder-product.jpg",
    "/placeholder-back.jpg",
    "/placeholder-detail.jpg",
  ],
};

export async function getStaticPaths() {
  const USE_MOCK = true;

  if (USE_MOCK) {
    return [
      {
        params: { handle: "intent" },
      },
    ];
  }

  const data = await shopifyFetch(GET_PRODUCT_HANDLES);
  const products = data.products;

  return products.map((product) => ({
    params: { handle: product.handle },
  }));
}
---

<SeoHead
  title={`${product.title} | MALYXIA`}
  description={`Shop ${product.title}`}
/>

<DefaultLayout>
  <!-- HERO STRIP -->
  <section class="max-w-6xl mx-auto px-6 pt-24 pb-12">
    <p class="text-xs uppercase tracking-widest opacity-50 mb-4">Chapter 1</p>

    <h1 class="text-4xl md:text-6xl font-bold tracking-tight">
      {product.title}
    </h1>

    <p class="mt-4 text-sm opacity-60">
      ${product.price}
    </p>
  </section>

  <!-- IMAGE LAYOUT TEST AREA -->
  <section class="max-w-6xl mx-auto px-6 grid lg:grid-cols-2 gap-6">
    <div class="lg:col-span-2">
      <img src={product.images[0]} class="w-full object-cover" />
    </div>

    <img src={product.images[1]} class="w-full object-cover" />

    <img src={product.images[2]} class="w-full object-cover" />
  </section>

  <!-- TEXT BLOCK -->
  <section class="max-w-3xl mx-auto px-6 py-20">
    <p class="text-sm opacity-70 leading-relaxed">
      A study in intent. Limited production garment. Built for controlled
      release.
    </p>
  </section>

  <!-- CTA -->
  <section class="max-w-3xl mx-auto px-6 pb-32">
    <button
      class="w-full border border-black py-3 text-sm uppercase tracking-wide"
    >
      Add to Cart
    </button>
  </section>
</DefaultLayout>
