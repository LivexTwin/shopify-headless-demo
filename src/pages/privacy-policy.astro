---
import DefaultLayout from "../layouts/DefaultLayout.astro";
---

<DefaultLayout>
  <section
    class="max-w-2xl mx-auto px-6 py-24 font-mono text-xs leading-relaxed uppercase"
  >
    <h1 class="mb-10 opacity-60">Malyxia Privacy Policy</h1>

    <p class="mb-6">
      MALYXIA respects your privacy and is committed to protecting any personal
      information you provide.
    </p>

    <p class="mb-6">
      We collect only the information necessary to process orders, including
      your name, email, shipping address, and payment details. Payments are
      processed securely through third-party providers. MALYXIA does not store
      full payment information.
    </p>

    <p class="mb-6">
      Your information is used solely for order fulfillment, customer support,
      and basic site functionality.
    </p>

    <p class="mb-6">
      We may use basic analytics tools to understand site traffic and improve
      performance. These tools do not personally identify you.
    </p>

    <p class="mb-6">
      We do not sell or share your personal information with third parties for
      marketing purposes.
    </p>

    <p class="mb-10">
      If you have any questions about your data, you can contact us at
      <span class="lowercase">support@malyxia.xyz</span>.
    </p>

    <!-- FOOT LINKS -->
    <div class="mt-12 border-t pt-6 flex justify-between text-xs opacity-70">
      <a href="/info" class="hover:opacity-100">Info</a>
      <a href="/" class="hover:opacity-100">MALYXIA</a>
    </div>
  </section>
</DefaultLayout>
