---
// src/pages/404.astro
import DefaultLayout from "../layouts/DefaultLayout.astro";
---

<DefaultLayout>
  <section
    class="min-h-screen flex flex-col items-center justify-center text-center px-6 font-mono uppercase"
  >
    <h1 class="text-6xl mb-4 tracking-tight">404</h1>

    <p class="text-xs opacity-60 mb-10">This page does not exist.</p>

    <a
      href="/"
      class="text-xs border border-black rounded-[2px] px-6 py-3 hover:bg-black hover:text-white transition"
    >
      Return
    </a>
  </section>
</DefaultLayout>
