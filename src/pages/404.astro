---
// src/pages/404.astro
import DefaultLayout from "../layouts/DefaultLayout.astro";
---

<DefaultLayout>
  <section class="text-center py-20 px-6">
    <h1 class="text-5xl font-bold mb-4 text-red-600">404</h1>
    <p class="text-xl mb-6">Oops! The page you're looking for doesn't exist.</p>
    <a
      href="/"
      class="inline-block px-6 py-3 bg-black text-white font-medium rounded hover:bg-gray-800 transition"
    >
      Go back home
    </a>
  </section>
</DefaultLayout>
