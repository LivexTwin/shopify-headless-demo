---
import DefaultLayout from "../layouts/DefaultLayout.astro";
import { shopifyFetch } from "../lib/shopify.ts";
import { GET_DROP_PRODUCT } from "../lib/queries/products.ts";
import { normalizeProductImages } from "../lib/normalizeProductImages.ts";
import SeoHead from "../components/SeoHead.astro";
import ProductMediaGallery from "../components/Product/ProductMediaGallery.svelte";

const data = await shopifyFetch(GET_DROP_PRODUCT);

const rawProduct = data.products.nodes[0];

const product = {
  ...rawProduct,
  images: normalizeProductImages(rawProduct),
};
---

<SeoHead title="MALYXIA — Chapter 1" />
<DefaultLayout>
  <!-- HERO -->
  <section
    class="min-h-screen flex flex-col justify-center items-center text-center px-6"
  >
    <h1 class="text-5xl md:text-7xl font-bold tracking-tight">INTENT</h1>
    <p class="mt-4 text-sm uppercase tracking-widest opacity-60">Chapter 1</p>
  </section>

  <!-- TRANSITION -->
  <section class="py-16 text-center px-6">
    <p class="text-sm uppercase tracking-wider opacity-70">
      Designed with intention. Limited to 18.
    </p>
  </section>
  <!-- PRODUCT -->
  <section class="py-16 px-6 max-w-4xl mx-auto">
    <div class="flex flex-col md:flex-row gap-10 items-start">
      <!-- IMAGE -->
      <!-- FRONT AND BACK SLIDER -->
      <div class="w-full md:w-1/2">
        <ProductMediaGallery
          client:load
          images={product.images}
          altBase={product.title}
          variant="compact"
        />
      </div>
      <!-- INFO -->
      <div class="w-full md:w-1/2">
        <h2 class="text-xl font-semibold">{product.title}</h2>
        <p class="mt-2 text-lg">${product.price}</p>
        <!-- SIZE SELECT -->
        <div class="mt-6">
          <label class="block text-xs mb-2 uppercase tracking-wide">
            Size
          </label>
          <select class="w-full border p-2 text-sm">
            <option>S</option>
            <option>M</option>
            <option>L</option>
            <option>XL</option>
          </select>
        </div>
        <!-- CTA -->
        <button
          class="mt-6 w-full border border-black py-3 text-sm uppercase tracking-wide"
        >
          Add to Cart
        </button>
      </div>
    </div>
  </section>
</DefaultLayout>
