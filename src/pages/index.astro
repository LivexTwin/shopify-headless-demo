---
import DefaultLayout from "../layouts/DefaultLayout.astro";
import { shopifyFetch } from "../lib/shopify.ts";
import { GET_DROP_PRODUCT } from "../lib/queries/products.ts";

import SeoHead from "../components/SeoHead.astro";
import ProductMediaGallery from "../components/Product/ProductMediaGallery.svelte";
import ProductPurchaseBlock from "../components/Product/ProductPurchaseBlock.svelte";

const data = await shopifyFetch(GET_DROP_PRODUCT);

const product = data.products.nodes[0];
---

<SeoHead title="MALYXIA — Chapter 1" />
<DefaultLayout>
  <!-- HERO -->
  <section
    class="min-h-screen flex flex-col justify-center items-center text-center px-6"
  >
    <h1 class="text-5xl md:text-7xl font-bold tracking-tight">INTENT</h1>
    <p class="mt-4 text-sm uppercase tracking-widest opacity-60">Chapter 1</p>
  </section>

  <!-- TRANSITION -->
  <section class="py-16 text-center px-6">
    <p class="text-sm uppercase tracking-wider opacity-70">
      Designed with intention. Limited to 18.
    </p>
  </section>
  <!-- PRODUCT -->
  <section class="py-16 px-6 max-w-4xl mx-auto">
    <div class="flex flex-col md:flex-row md:items-center gap-10 items-start">
      <!-- IMAGE -->
      <!-- FRONT AND BACK SLIDER -->
      <div class="w-full md:w-2/3">
        <ProductMediaGallery
          client:load
          images={product.images}
          altBase={product.title}
          variant="compact"
        />
      </div>
      <!-- INFO -->

      <div class="md:w-1/3">
        <a href={`/products/${product.handle}`}>
          <h2 class="uppercase">{product.title}</h2>
        </a>

        <!-- Product Purchase Block -->
        <ProductPurchaseBlock
          client:only="svelte"
          product={product}
          mode="quick"
        />
      </div>
    </div>
  </section>
</DefaultLayout>
