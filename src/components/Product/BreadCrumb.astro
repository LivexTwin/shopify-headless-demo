---
// Breadcrumb.astro
export interface Props {
  title: string;
}
const { title } = Astro.props as Props;
---

<nav aria-label="Breadcrumb" class="mb-4">
  <ol
    class="flex items-center gap-1 overflow-hidden bg-white text-sm text-gray-700"
  >
    <li>
      <a
        href="/"
        class="block h-10 px-4 leading-10 transition-colors hover:text-blue-600"
      >
        Shop
      </a>
    </li>

    <li class="rtl:rotate-180">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-4 w-4 text-gray-400"
        viewBox="0 0 20 20"
        fill="currentColor"
      >
        <path
          fill-rule="evenodd"
          d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
          clip-rule="evenodd"></path>
      </svg>
    </li>

    <li>
      <span
        class="block h-10 px-4 leading-10 font-semibold text-blue-700"
        aria-current="page"
      >
        {title}
      </span>
    </li>
  </ol>
</nav>
