---
import ProductCard from "./ProductCard.astro";
const { products } = Astro.props;
---

<div class="max-w-7xl mx-auto px-4 pt-10 pb-8 sm:px-6 lg:px-8">
  <ul
    class="product-list grid gap-6 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4"
  >
    {
      products.map((product, index) => (
        <li key={product.id}>
          <ProductCard product={product} eager={index < 2} />
        </li>
      ))
    }
  </ul>
</div>
