---
const { product, eager = false } = Astro.props;

import ShopifyImage from "../ShopifyImage.svelte";
import Money from "../Money.svelte";
import SoldOut from "./SoldOut.svelte";
const featuredImage = product.images?.[0] || null;
---

<article
  class="animate-fade-in group bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-all duration-200"
>
  <a href={`/products/${product.handle}`} class="block p-4">
    <div class="relative aspect-square overflow-hidden rounded-lg bg-gray-50">
      <div
        class="w-full h-full transition-transform duration-300 group-hover:scale-105 rounded-lg overflow-hidden"
      >
        <ShopifyImage
          image={{
            url: featuredImage.url,
            altText: featuredImage.altText || product.title,
            width: 300,
            height: 300,
          }}
          loading={eager ? "eager" : "lazy"}
          classList="w-full h-full object-cover"
          sizes="(max-width: 600px) 100vw, 300px"
        />
      </div>

      <div class="absolute top-2 right-2 z-10">
        <SoldOut variants={product.variants} />
      </div>
    </div>

    <div class="mt-4 flex flex-col gap-1">
      <h2
        class="text-base font-medium text-gray-900 group-hover:text-blue-700 transition-colors"
      >
        {product.title}
      </h2>

      <Money
        amount={product.variants?.[0]?.price.amount}
        currencyCode={product.variants?.[0]?.price.currencyCode}
      />
    </div>
  </a>
</article>
